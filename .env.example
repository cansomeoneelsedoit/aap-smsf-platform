# --- Database ---
# Local dev (docker-compose runs Postgres on host 5433 to avoid clashing with
# sparmanikfarm's 5432; inside the compose network the web service uses host
# `db` on the container-side 5432).
DATABASE_URL="postgresql://smsfecho:smsfecho@localhost:5433/smsfecho?schema=public"

# Railway Postgres requires SSL — the pg client handles this when ?sslmode=require
# is appended. Set DATABASE_SSL=false to disable locally.
DATABASE_SSL=false

# --- Auth.js (NextAuth v5) ---
# Generate with: openssl rand -base64 32
AUTH_SECRET="change-me-in-prod"
AUTH_URL="http://localhost:3001"
AUTH_TRUST_HOST=true

# --- Google OAuth (optional v1) ---
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# --- File uploads ---
# Path the web container writes uploads to. Dev: ./uploads. Prod on Railway:
# mount a Volume at /data and set UPLOAD_DIR=/data/uploads.
UPLOAD_DIR=

# --- Misc ---
NODE_ENV=development
