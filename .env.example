# Production database
DATABASE_URL="postgresql://user:password@host:5432/railway"

# Demo database (same Railway Postgres instance, different db name)
DEMO_DATABASE_URL="postgresql://user:password@host:5432/aap_demo"

# Toggle demo mode: "true" uses DEMO_DATABASE_URL and shows banner
DEMO_MODE="true"

# Better Auth
BETTER_AUTH_SECRET="generate-with-openssl-rand-base64-32"
# Must match the origin you use in the browser (check terminal if Next picks another port)
BETTER_AUTH_URL="http://localhost:3000"



# 3CX — base URL of your PBX web client, used for click-to-call deep links
# (e.g. https://yourpbx.3cx.com.au)
NEXT_PUBLIC_THREECX_WEBCLIENT_URL=


# Microsoft (Azure app registration — used for staff sign-in and SharePoint Graph API)
# Redirect URI: {BETTER_AUTH_URL}/api/auth/callback/microsoft
# Delegated permissions: openid, profile, email, User.Read
MICROSOFT_CLIENT_ID=""
MICROSOFT_CLIENT_SECRET=""
MICROSOFT_TENANT_ID=""