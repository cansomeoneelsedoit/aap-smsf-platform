generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum AccountType {
  STAFF
  CLIENT
}

enum StaffRole {
  MASTER_OWNER
  BOOKKEEPER
  COMPLIANCE_OFFICER
  TAX_AGENT
}

enum Stage {
  Start
  Prepare
  Check
  Lodge
  Active
}

enum PartyType {
  PERSON
  COMPANY
  TRUST
}

enum PartyRole {
  TRUSTEE
  DIRECTOR
  AUTHORISED_PARTY
  MEMBER
}

model User {
  id            String      @id
  name          String
  email         String
  emailVerified Boolean     @default(false)
  image         String?
  phone         String?
  accountType   AccountType
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  sessions         Session[]
  accounts         Account[]
  staffProfile     StaffProfile?
  personDetails    PersonDetails?
  ownedMatters     Matter[]          @relation("MatterOwner")
  auditEntries     AuditEntry[]
  fileNotes        FileNote[]
  assignedTasks    Task[]            @relation("TaskAssignee")
  stageAssignments StageAssignment[]

  @@unique([email])
  @@map("user")
}

model Session {
  id        String   @id
  expiresAt DateTime
  token     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  ipAddress String?
  userAgent String?
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([token])
  @@map("session")
}

model Account {
  id                    String    @id
  accountId             String
  providerId            String
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@map("account")
}

model Verification {
  id         String    @id
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime?
  updatedAt  DateTime?

  @@map("verification")
}

model StaffProfile {
  userId   String    @id
  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  role     StaffRole
  initials String
  color    String
  hobbies  String?
}

/// The organisation whose clients we administer (e.g. AAP, Liberty).
model Organisation {
  id           String  @id
  name         String
  description  String
  contactName  String
  contactEmail String
  letter       String  @db.Char(1)
  bgColor      String
  textColor    String
  cbClass      String
  clients      Party[]
  microsoftIntegration OrganisationMicrosoftIntegration?
}

model OrganisationMicrosoftIntegration {
  organisationId    String       @id
  organisation      Organisation @relation(fields: [organisationId], references: [id], onDelete: Cascade)
  microsoftTenantId String?      @map("microsoft_tenant_id")
  sharepointSiteId  String?      @map("sharepoint_site_id")
  sharepointDriveId String?      @map("sharepoint_drive_id")

  @@map("organisation_microsoft_integrations")
}

/// Any legal person: an individual, a company, or a trust (an SMSF is a trust).
/// A "client" is a Party of type TRUST referenced by Matter.clientId.
model Party {
  id             String        @id @default(cuid())
  type           PartyType
  name           String
  organisationId String?
  organisation   Organisation? @relation(fields: [organisationId], references: [id])
  sharepointDriveId  String? @map("sharepoint_drive_id")
  sharepointFolderId String? @map("sharepoint_folder_id")
  sharepointFolderPath String? @map("sharepoint_folder_path")
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  person  PersonDetails?
  company CompanyDetails?
  trust   TrustDetails?

  relationsOut PartyRelationship[] @relation("ParentParty")
  relationsIn  PartyRelationship[] @relation("ChildParty")
  matters      Matter[]
}

model PersonDetails {
  partyId   String  @id
  party     Party   @relation(fields: [partyId], references: [id], onDelete: Cascade)
  firstName String
  lastName  String
  email     String?
  phone     String?
  userId    String? @unique
  user      User?   @relation(fields: [userId], references: [id], onDelete: SetNull)
}

model CompanyDetails {
  partyId String  @id
  party   Party   @relation(fields: [partyId], references: [id], onDelete: Cascade)
  acn     String?
}

model TrustDetails {
  partyId String  @id
  party   Party   @relation(fields: [partyId], references: [id], onDelete: Cascade)
  abn     String?
}

/// Role edge between parties: trust -> trustee (person or company),
/// company -> director (person), trust -> authorised party, etc.
model PartyRelationship {
  id            String    @id @default(cuid())
  parentPartyId String
  parentParty   Party     @relation("ParentParty", fields: [parentPartyId], references: [id], onDelete: Cascade)
  childPartyId  String
  childParty    Party     @relation("ChildParty", fields: [childPartyId], references: [id], onDelete: Cascade)
  role          PartyRole

  @@unique([parentPartyId, childPartyId, role])
}

model Matter {
  id         String    @id @default(cuid())
  displayId  String    @unique
  name       String
  subtitle   String?
  matterType String
  stage      Stage
  dueDate    DateTime?
  clientId   String
  client     Party     @relation(fields: [clientId], references: [id])
  ownerId    String?
  owner      User?     @relation("MatterOwner", fields: [ownerId], references: [id])
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  tasks        Task[]
  fileNotes    FileNote[]
  auditEntries AuditEntry[]
}

model Task {
  id          String    @id @default(cuid())
  matterId    String
  matter      Matter    @relation(fields: [matterId], references: [id], onDelete: Cascade)
  title       String
  done        Boolean   @default(false)
  dueDate     DateTime?
  assigneeId  String?
  assignee    User?     @relation("TaskAssignee", fields: [assigneeId], references: [id])
  completedAt DateTime?
  createdAt   DateTime  @default(now())
}

model FileNote {
  id        String   @id @default(cuid())
  matterId  String
  matter    Matter   @relation(fields: [matterId], references: [id], onDelete: Cascade)
  authorId  String
  author    User     @relation(fields: [authorId], references: [id])
  type      String
  subject   String
  body      String   @db.Text
  tags      String[]
  pinned    Boolean  @default(false)
  draft     Boolean  @default(false)
  createdAt DateTime @default(now())
}

model AuditEntry {
  id        String   @id @default(cuid())
  matterId  String?
  matter    Matter?  @relation(fields: [matterId], references: [id], onDelete: SetNull)
  userId    String?
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  action    String
  detail    String
  entity    String
  createdAt DateTime @default(now())
}

model StageAssignment {
  stage   Stage  @id
  staffId String
  staff   User   @relation(fields: [staffId], references: [id])
}
